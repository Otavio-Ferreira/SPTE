                                  // Calcula a porcentagem para desenhar a barra de progresso
                                  $presenca = intval($freq['assiduidade']);
                                  $total = intval($freq['total_aulas_prevista']);
                                  $porcentagem = ($total > 0) ? round(($presenca / $total) * 100) : 0;
                                  
                                  // Define a cor da barra baseada no risco (< 75% é vermelho)
                                  $corBarra = 'bg-success';
                                  if ($porcentagem < 75) $corBarra = 'bg-danger';
                                  elseif ($porcentagem < 85) $corBarra = 'bg-warning';
                              ?>
                              <tr>
                                  <td class="text-muted fw-bold">Mês <?= htmlspecialchars($freq['mes']); ?>/<?= htmlspecialchars($freq['ano']); ?></td>
                                  <td class="text-start">
                                      <div class="d-flex align-items-center gap-2">
                                          <div class="progress flex-grow-1" style="height: 10px;">
                                              <div class="progress-bar <?= $corBarra ?>" role="progressbar" style="width: <?= $porcentagem ?>%" aria-valuenow="<?= $porcentagem ?>" aria-valuemin="0" aria-valuemax="100"></div>
                                          </div>
                                          <span class="small fw-bold <?= ($porcentagem < 75) ? 'text-danger' : 'text-success' ?>">
                                              <?= htmlspecialchars($freq['assiduidade']); ?>/<?= htmlspecialchars($freq['total_aulas_prevista']); ?> (<?= $porcentagem ?>%)
                                          </span>
                                      </div>
                                  </td>
                              </tr>
                          <?php endforeach; ?>
                      <?php else: ?>
